# Copy to .env and replace every required value before starting Docker Compose.
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
APP_ORIGIN=https://fairshare.example.com
FAIRSHARE_SETUP_TOKEN=replace-with-a-long-random-one-time-setup-token
CRON_SECRET=replace-with-a-different-long-random-scheduler-secret

# Optional Web Push. Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional comma-separated exact hosts or .domain suffixes for additional push providers.
PUSH_ALLOWED_HOSTS=
